{
  "name": "@better-agent/provider-config-sync-ui",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:mcp": "esbuild src/mcp-app.tsx --bundle --format=iife --outfile=../provider-config-sync-backend/src/provider_config_sync_backend/static/mcp-app.js --loader:.css=css",
    "build:standalone": "esbuild src/standalone-app.tsx --bundle --format=iife --outfile=../provider-config-sync-backend/src/provider_config_sync_backend/static/standalone-app.js --loader:.css=css",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@better-agent/provider-config-sync-core": "*"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.7",
    "esbuild": "^0.28.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~5.9.3"
  }
}
