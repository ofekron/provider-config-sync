{
  "name": "provider-config-sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/provider-config-sync-core",
    "packages/provider-config-sync-ui"
  ],
  "scripts": {
    "build:core": "npm --prefix packages/provider-config-sync-core run build",
    "build:ui": "npm --prefix packages/provider-config-sync-ui run build",
    "build:mcp-ui": "npm --prefix packages/provider-config-sync-ui run build:mcp",
    "build:standalone-ui": "npm --prefix packages/provider-config-sync-ui run build:standalone",
    "build:assets": "npm run build:mcp-ui && npm run build:standalone-ui",
    "standalone": "PYTHONPATH=packages/provider-config-sync-backend/src python -m provider_config_sync_backend.standalone"
  }
}
